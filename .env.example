# --- 로컬 개발 (npm run dev) ---
# 생략 시 기본: http://localhost:5001/todos
# VITE_API_BASE_URL=http://127.0.0.1:5001/todos

# --- Vercel 프로덕션 ---
# 브라우저에 박히므로 공개 HTTPS만. 127.0.0.1은 빌드에서 자동 무시 → /api/todos 프록시 사용
# VITE_API_BASE_URL=https://your-api.example.com/todos

# Vercel 서버리스 프록시 — 아래 중 하나(공개 HTTPS, /todos 까지). localhost 는 무시됨.
# TODO_API_BASE_URL=https://your-api.example.com/todos
# (TODO 미설정 시) VITE_API_BASE_URL 이 공개 URL이면 프록시가 같은 값을 사용합니다.
